{
  "name": "predict-alpha",
  "version": "1.0.0",
  "description": "Prediction-Powered Trading Agent for OKX AI Hackathon",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "monitor": "tsx src/index.ts --mode=monitor",
    "backtest": "tsx src/index.ts --mode=backtest",
    "dev": "tsx watch src/index.ts",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.35.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
